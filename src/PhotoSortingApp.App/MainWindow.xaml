<Window x:Class="PhotoSortingApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="PhotoSortingApp"
        Icon="/PhotoSortingApp.App;component/Assets/PhotoSortingApp.ico"
        Height="960"
        Width="1540"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <CollectionViewSource x:Key="YearAlbumsView"
                              Source="{Binding SmartAlbums}"
                              Filter="YearAlbumsFilter" />
        <ContextMenu x:Key="PhotoItemContextMenu"
                     Background="{DynamicResource ControlPopupBackgroundBrush}"
                     BorderBrush="{DynamicResource ControlPopupBorderBrush}"
                     Foreground="{DynamicResource ControlForegroundBrush}">
            <ContextMenu.Resources>
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Background" Value="{DynamicResource ControlPopupBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
                    <Setter Property="Padding" Value="12,6" />
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ControlSelectionBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ControlSelectionForegroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="{x:Type Separator}">
                    <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
                    <Setter Property="Margin" Value="4,3" />
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="Open File"
                      Click="OnContextOpenFileClick" />
            <MenuItem Header="Open File Location"
                      Click="OnContextOpenFileLocationClick" />
            <Separator />
            <MenuItem Header="Save Media IDs"
                      Click="OnContextSaveMediaClick" />
            <MenuItem Header="Move"
                      Click="OnContextMoveClick" />
            <MenuItem Header="Copy"
                      Click="OnContextCopyClick" />
            <MenuItem Header="Duplicate"
                      Click="OnContextDuplicateClick" />
            <MenuItem Header="Fix Location"
                      Click="OnContextFixLocationClick" />
        </ContextMenu>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="12,12,12,8"
                Padding="12"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,10"
                           LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               FontSize="18"
                               FontWeight="Bold"
                               Text="Photo Workspace" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Scan, filter, and organize with less clutter." />
                </DockPanel>

                <Grid Grid.Row="1"
                      Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="Root Folder" />
                    <ComboBox Grid.Column="1"
                              MinWidth="380"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding ScanRoots}"
                              SelectedItem="{Binding SelectedScanRoot}" />
                </Grid>

                <CheckBox Grid.Row="2"
                          Margin="0,0,0,10"
                          IsChecked="{Binding ExcludeSystemMedia, Mode=TwoWay}"
                          Content="Exclude system/app media during scan and browsing (recommended)" />

                <WrapPanel Grid.Row="3"
                           Margin="0,0,0,8"
                           VerticalAlignment="Center">
                    <Button Margin="0,0,8,8"
                            Padding="10,6"
                            Command="{Binding SelectFolderCommand}"
                            Content="Select Folder" />
                    <Button Margin="0,0,8,8"
                            Padding="10,6"
                            Command="{Binding RefreshScanRootsCommand}"
                            Content="Refresh Roots" />
                    <Button Margin="0,0,8,8"
                            Padding="10,6"
                            Command="{Binding RescanCommand}"
                            Content="Start Scan" />
                    <Button Margin="0,0,8,8"
                            Padding="10,6"
                            Command="{Binding ScanWholeComputerCommand}"
                            ToolTip="Scans fixed drives using safe exclusions to avoid system/program image noise."
                            Content="Scan This PC" />
                    <Button Margin="0,0,8,8"
                            Padding="10,6"
                            Command="{Binding CancelScanCommand}"
                            Content="Cancel Scan" />
                </WrapPanel>

                <WrapPanel Grid.Row="4"
                           VerticalAlignment="Center">
                    <StackPanel Width="250"
                                Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Search" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding ApplyFiltersCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Width="160"
                                Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Person ID" />
                        <TextBox Text="{Binding PersonSearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding ApplyFiltersCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Width="160"
                                Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Animal ID" />
                        <TextBox Text="{Binding AnimalSearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding ApplyFiltersCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Width="170"
                                Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Location ID" />
                        <TextBox Text="{Binding LocationSearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding ApplyFiltersCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Width="120"
                                Margin="0,0,12,8">
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Theme" />
                        <ComboBox DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding SelectedThemeOption}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,8">
                        <Button Margin="0,0,8,0"
                                Padding="10,6"
                                Command="{Binding ApplyFiltersCommand}"
                                Content="Apply Filters" />
                        <Button Padding="10,6"
                                Command="{Binding ClearFiltersCommand}"
                                Content="Clear Filters" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="12,0,12,8"
                Padding="8"
                Background="{DynamicResource AccentSoftBrush}"
                BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel LastChildFill="True">
                <ProgressBar DockPanel.Dock="Right"
                             Width="260"
                             Height="16"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Maximum="100"
                             Value="{Binding IndexingPercent, Mode=OneWay}" />
                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="{Binding IndexingStatus}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2"
              Margin="12,0,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Library Filters" />
                        <CheckBox Margin="0,0,0,10"
                                  IsChecked="{Binding EnableDuplicateDetection, Mode=TwoWay}"
                                  Content="Enable duplicate detection (SHA-256 on scan)" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Year Folders" />
                        <TextBlock Margin="0,2,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Browse photos by year, like folders."
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Tip: Select a year, then Build Plan to auto-file that year."
                                   TextWrapping="Wrap" />
                        <ListBox Height="140"
                                 Margin="0,4,0,10"
                                 DisplayMemberPath="DisplayName"
                                 ItemsSource="{Binding Source={StaticResource YearAlbumsView}}"
                                 SelectedItem="{Binding SelectedAlbum}" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Smart Albums" />
                        <ListBox Height="120"
                                 Margin="0,4,0,10"
                                 DisplayMemberPath="DisplayName"
                                 ItemsSource="{Binding SmartAlbums}"
                                 SelectedItem="{Binding SelectedAlbum}" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Date Range" />
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0"
                                        Margin="0,0,4,0"
                                        SelectedDate="{Binding FromDateLocal}" />
                            <DatePicker Grid.Column="1"
                                        Margin="4,0,0,0"
                                        SelectedDate="{Binding ToDateLocal}" />
                        </Grid>

                        <TextBlock FontWeight="SemiBold"
                                   Text="Date Source" />
                        <ComboBox Margin="0,4,0,8"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding DateSourceOptions}"
                                  SelectedItem="{Binding SelectedDateSource}" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Folder Filter" />
                        <ComboBox Margin="0,4,0,10"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding FolderFilters}"
                                  SelectedItem="{Binding SelectedFolderFilter}" />

                        <DockPanel Margin="0,0,0,4"
                                   LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Margin="0,0,8,0"
                                       FontWeight="SemiBold"
                                       Text="Duplicate Groups" />
                            <Button DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Padding="8,2"
                                    Command="{Binding RefreshDuplicatesCommand}"
                                    Content="Refresh" />
                        </DockPanel>
                        <ListBox Height="180"
                                 Margin="0,4,0,0"
                                 DisplayMemberPath="DisplayName"
                                 ItemsSource="{Binding DuplicateGroups}"
                                 SelectedItem="{Binding SelectedDuplicateGroup}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,8"
                               LastChildFill="True">
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center">
                            <CheckBox Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IncludeImages, Mode=TwoWay}"
                                      Content="Images" />
                            <CheckBox Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IncludeVideos, Mode=TwoWay}"
                                      Content="Videos" />
                            <TextBlock Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="Sort:" />
                            <ComboBox Width="170"
                                      Margin="0,0,10,0"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}" />
                            <TextBlock Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="Layout:" />
                            <ComboBox Width="95"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding LayoutOptions}"
                                      SelectedItem="{Binding SelectedLayoutOption}" />
                        </StackPanel>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding ResultsSummary, StringFormat=Gallery - {0}}" />
                        <TextBlock Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding SelectedPhotosSummary}" />
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <ListBox x:Name="TilePhotosList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding Photos}"
                                 SelectedItem="{Binding SelectedPhoto}"
                                 SelectionMode="Extended"
                                  SelectionChanged="PhotoList_SelectionChanged"
                                 PreviewMouseRightButtonDown="PhotoList_PreviewMouseRightButtonDown"
                                 MouseDoubleClick="PhotoList_MouseDoubleClick"
                                 Visibility="{Binding IsTileLayout, Converter={StaticResource BoolToVisibilityConverter}}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="170"
                                            Height="190"
                                            Margin="6"
                                            Padding="6"
                                            ContextMenu="{StaticResource PhotoItemContextMenu}"
                                            Background="{DynamicResource TileBackgroundBrush}"
                                            BorderBrush="{DynamicResource TileBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <Border Height="120"
                                                    Background="{DynamicResource SurfaceMutedBrush}"
                                                    CornerRadius="4">
                                                <Image Source="{Binding ThumbnailImage}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding DateTakenText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding MediaTypeText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox x:Name="ListPhotosList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding Photos}"
                                 SelectedItem="{Binding SelectedPhoto}"
                                 SelectionMode="Extended"
                                 SelectionChanged="PhotoList_SelectionChanged"
                                 PreviewMouseRightButtonDown="PhotoList_PreviewMouseRightButtonDown"
                                 MouseDoubleClick="PhotoList_MouseDoubleClick"
                                 Visibility="{Binding IsTileLayout, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            ContextMenu="{StaticResource PhotoItemContextMenu}"
                                            Background="{DynamicResource TileBackgroundBrush}"
                                            BorderBrush="{DynamicResource TileBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="84"
                                                    Height="84"
                                                    Background="{DynamicResource SurfaceMutedBrush}"
                                                    CornerRadius="4">
                                                <Image Source="{Binding ThumbnailImage}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,0,0">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding DateTakenText}" />
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding FileSizeText}" />
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding ResolutionText}" />
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding MediaTypeText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <DockPanel Grid.Row="2"
                               Margin="0,8,0,0"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Tip: Double-click any photo/video to open the original file." />
                        <Button DockPanel.Dock="Right"
                                Padding="10,6"
                                Command="{Binding LoadMoreCommand}"
                                Content="Load More" />
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Inspector" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Preview" />
                        <Border Height="240"
                                Margin="0,4,0,8"
                                Background="{DynamicResource SurfaceMutedBrush}"
                                CornerRadius="4">
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform" />
                        </Border>

                        <TextBlock FontWeight="SemiBold"
                                   Text="Media Details" />
                        <Grid Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="File:" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.FileName}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Path:" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.FullPath}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Date Taken:" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.DateTakenText}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Resolution:" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.ResolutionText}" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Camera:" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.Camera}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Text="SHA-256:" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.Asset.Sha256}"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Text="Notes:" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.Asset.Notes}" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Text="People IDs:" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Text="{Binding DetectedPeopleText}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Text="Animal IDs:" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Text="{Binding DetectedAnimalsText}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Text="Location IDs:" />
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Text="{Binding DetectedLocationsText}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Text="Media Type:" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="1"
                                       Text="{Binding SelectedPhoto.MediaTypeText}" />
                        </Grid>

                        <TextBlock FontWeight="SemiBold"
                                   Text="Rename Assistant" />
                        <ComboBox Margin="0,4,0,6"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding RenameSuggestions}"
                                  SelectedItem="{Binding SelectedRenameSuggestion}" />
                        <TextBox Margin="0,0,0,6"
                                 Text="{Binding RenameInput, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Format: yyyyMMdd_HHmmss_subject_context.ext"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding SmartRenameSummary}"
                                   TextWrapping="Wrap" />
                        <StackPanel Margin="0,0,0,10"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding ApplyRenameSuggestionCommand}"
                                    Content="Use Suggestion" />
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding SmartRenameSelectedCommand}"
                                    Content="Smart Rename Selected" />
                            <Button Padding="10,6"
                                    Command="{Binding RenamePhotoCommand}"
                                    Content="Rename" />
                        </StackPanel>

                        <TextBlock FontWeight="SemiBold"
                                   Text="Identity and Metadata" />
                        <TextBlock Margin="0,4,0,6"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding SelectedPhotosSummary}" />
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Scan for IDs, edit manually, then Save IDs to all selected photos."
                                   TextWrapping="Wrap" />
                        <TextBlock Text="People IDs (comma-separated):" />
                        <TextBox Margin="0,4,0,6"
                                 ToolTip="Example: alice,bob,team_lead"
                                 Text="{Binding PeopleInputText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SaveImageCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock Text="Animal IDs (comma-separated):" />
                        <TextBox Margin="0,4,0,6"
                                 ToolTip="Example: dog_1,cat_2"
                                 Text="{Binding AnimalInputText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SaveImageCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock Text="Location IDs (comma-separated):" />
                        <TextBox Margin="0,4,0,6"
                                 ToolTip="Example: denver_office,boston_hq,nyc_trip"
                                 Text="{Binding LocationInputText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SaveImageCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <StackPanel Margin="0,0,0,10"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding IdentifyPeopleAnimalsCommand}"
                                    Content="Scan People / Animals" />
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding SaveDetectedSubjectsCommand}"
                                    Content="Save IDs" />
                            <Button Padding="10,6"
                                    Command="{Binding SaveImageCommand}"
                                    Content="Save Media" />
                        </StackPanel>
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding ContextScanSummary}"
                                   TextWrapping="Wrap" />
                        <Button Margin="0,0,0,10"
                                Padding="10,6"
                                Command="{Binding ScanContextTagsCommand}"
                                Content="Scan Environment / Event / Scene Tags" />

                        <TextBlock FontWeight="SemiBold"
                                   Text="Tags" />
                        <ListBox Height="95"
                                 Margin="0,4,0,6"
                                 ItemsSource="{Binding PhotoTags}"
                                 SelectedItem="{Binding SelectedTag}" />
                        <TextBox Margin="0,0,0,6"
                                 ToolTip="Use commas to add multiple tags at once."
                                 Text="{Binding TagInputText, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Margin="0,0,0,10"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding AddTagCommand}"
                                    Content="Add Tag" />
                            <Button Margin="0,0,8,0"
                                    Padding="10,6"
                                    Command="{Binding UpdateTagCommand}"
                                    Content="Edit Tag" />
                            <Button Padding="10,6"
                                    Command="{Binding RemoveTagCommand}"
                                    Content="Remove Tag" />
                        </StackPanel>

                        <TextBlock FontWeight="SemiBold"
                                   Text="File Actions" />
                        <WrapPanel Margin="0,4,0,10">
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding OpenPhotoCommand}"
                                    Content="Open File" />
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding OpenFileLocationCommand}"
                                    Content="Open File Location" />
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding MovePhotoCommand}"
                                    Content="Move" />
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding CopyPhotoCommand}"
                                    Content="Copy" />
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding DuplicatePhotoCommand}"
                                    Content="Duplicate" />
                            <Button Margin="0,0,8,8"
                                    Padding="10,6"
                                    Command="{Binding RepairPhotoLocationCommand}"
                                    Content="Fix Location" />
                        </WrapPanel>

                        <Expander Margin="0,0,0,10"
                                  IsExpanded="False"
                                  Header="Undo History">
                            <StackPanel Margin="0,8,0,0">
                                <ComboBox Margin="0,0,0,6"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding UndoHistory}"
                                          SelectedItem="{Binding SelectedUndoAction}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Margin="0,0,8,0"
                                            Padding="10,6"
                                            Command="{Binding UndoLastChangeCommand}"
                                            Content="Undo Last" />
                                    <Button Padding="10,6"
                                            Command="{Binding UndoSelectedChangeCommand}"
                                            Content="Undo Selected" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="False"
                                  Header="Organizer Plan (Dry-Run)">
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding PlanSummary}" />
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Button Margin="0,0,8,0"
                                            Padding="10,6"
                                            Command="{Binding BuildOrganizerPlanCommand}"
                                            Content="Build Plan" />
                                    <Button Padding="10,6"
                                            Command="{Binding ApplyOrganizerPlanCommand}"
                                            Content="Apply Plan" />
                                </StackPanel>
                                <DataGrid Height="240"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding OrganizerPreviewItems}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding SourcePath}"
                                                            Header="Source"
                                                            Width="*" />
                                        <DataGridTextColumn Binding="{Binding DestinationPath}"
                                                            Header="Destination"
                                                            Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="12,0,12,12"
                Padding="10,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Text="Status" />
                <TextBlock Text="{Binding StatusMessage}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
